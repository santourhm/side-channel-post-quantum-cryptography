 262:.././simpleserial/simpleserial.c **** {
 263:.././simpleserial/simpleserial.c **** 	char c;
 264:.././simpleserial/simpleserial.c **** 	unsigned int len;
 265:.././simpleserial/simpleserial.c **** 	uint8_t (*fp)(uint8_t*, uint8_t);
 266:.././simpleserial/simpleserial.c **** 	uint8_t flags;
 267:.././simpleserial/simpleserial.c **** } ss_cmd;
 268:.././simpleserial/simpleserial.c **** static ss_cmd commands[MAX_SS_CMDS];
