  45:.././simpleserial/simpleserial.c **** 
  46:.././simpleserial/simpleserial.c **** int hex_decode(int len, char* ascii_buf, uint8_t* data_buf)
  47:.././simpleserial/simpleserial.c **** {
  48:.././simpleserial/simpleserial.c **** 	for(int i = 0; i < len; i++)
  49:.././simpleserial/simpleserial.c **** 	{
  50:.././simpleserial/simpleserial.c **** 		char n_hi = ascii_buf[2*i];
  51:.././simpleserial/simpleserial.c **** 		char n_lo = ascii_buf[2*i+1];
  52:.././simpleserial/simpleserial.c **** 
  53:.././simpleserial/simpleserial.c **** 		if(n_lo >= '0' && n_lo <= '9')
  54:.././simpleserial/simpleserial.c **** 			data_buf[i] = n_lo - '0';
  55:.././simpleserial/simpleserial.c **** 		else if(n_lo >= 'A' && n_lo <= 'F')
  56:.././simpleserial/simpleserial.c **** 			data_buf[i] = n_lo - 'A' + 10;
  57:.././simpleserial/simpleserial.c **** 		else if(n_lo >= 'a' && n_lo <= 'f')
  58:.././simpleserial/simpleserial.c **** 			data_buf[i] = n_lo - 'a' + 10;
  59:.././simpleserial/simpleserial.c **** 		else
  60:.././simpleserial/simpleserial.c **** 			return 1;
  61:.././simpleserial/simpleserial.c **** 
  62:.././simpleserial/simpleserial.c **** 		if(n_hi >= '0' && n_hi <= '9')
  63:.././simpleserial/simpleserial.c **** 			data_buf[i] |= (n_hi - '0') << 4;
  64:.././simpleserial/simpleserial.c **** 		else if(n_hi >= 'A' && n_hi <= 'F')
  65:.././simpleserial/simpleserial.c **** 			data_buf[i] |= (n_hi - 'A' + 10) << 4;
  66:.././simpleserial/simpleserial.c **** 		else if(n_hi >= 'a' && n_hi <= 'f')
  67:.././simpleserial/simpleserial.c **** 			data_buf[i] |= (n_hi - 'a' + 10) << 4;
  68:.././simpleserial/simpleserial.c **** 		else
  69:.././simpleserial/simpleserial.c **** 			return 1;
  70:.././simpleserial/simpleserial.c **** 	}
  71:.././simpleserial/simpleserial.c **** 
  72:.././simpleserial/simpleserial.c **** 	return 0;
  73:.././simpleserial/simpleserial.c **** }
