 277:.././simpleserial/simpleserial.c **** {
 278:.././simpleserial/simpleserial.c ****     uint8_t ncmds = num_commands & 0xFF;
 279:.././simpleserial/simpleserial.c ****     simpleserial_put('r', 0x01, &ncmds);
 280:.././simpleserial/simpleserial.c ****     return 0x00;
