  20:.././simpleserial/simpleserial.c **** #define CW_CRC 0x4D 
  21:.././simpleserial/simpleserial.c **** uint8_t ss_crc(uint8_t *buf, uint8_t len)
  22:.././simpleserial/simpleserial.c **** {
  23:.././simpleserial/simpleserial.c **** 	unsigned int k = 0;
  24:.././simpleserial/simpleserial.c **** 	uint8_t crc = 0x00;
  25:.././simpleserial/simpleserial.c **** 	while (len--) {
  26:.././simpleserial/simpleserial.c **** 		crc ^= *buf++;
  27:.././simpleserial/simpleserial.c **** 		for (k = 0; k < 8; k++) {
  28:.././simpleserial/simpleserial.c **** 			crc = crc & 0x80 ? (crc << 1) ^ CW_CRC: crc << 1;
  29:.././simpleserial/simpleserial.c **** 		}
  30:.././simpleserial/simpleserial.c **** 	}
  31:.././simpleserial/simpleserial.c **** 	return crc;
  32:.././simpleserial/simpleserial.c **** 
  33:.././simpleserial/simpleserial.c **** }
