  75:.././simpleserial/simpleserial.c **** typedef struct ss_cmd
  76:.././simpleserial/simpleserial.c **** {
  77:.././simpleserial/simpleserial.c **** 	char c;
  78:.././simpleserial/simpleserial.c **** 	unsigned int len;
  79:.././simpleserial/simpleserial.c **** 	uint8_t (*fp)(uint8_t, uint8_t, uint8_t, uint8_t *);
  80:.././simpleserial/simpleserial.c **** } ss_cmd;
  81:.././simpleserial/simpleserial.c **** static ss_cmd commands[MAX_SS_CMDS];
  82:.././simpleserial/simpleserial.c **** 
  83:.././simpleserial/simpleserial.c **** void ss_puts(char *x)
  84:.././simpleserial/simpleserial.c **** {
  85:.././simpleserial/simpleserial.c **** 	do {
  86:.././simpleserial/simpleserial.c **** 		putch(*x);
  87:.././simpleserial/simpleserial.c **** 	} while (*++x);
  88:.././simpleserial/simpleserial.c **** }
  89:.././simpleserial/simpleserial.c **** 
  90:.././simpleserial/simpleserial.c **** #define FRAME_BYTE 0x00
  91:.././simpleserial/simpleserial.c **** 
  92:.././simpleserial/simpleserial.c **** uint8_t check_version(uint8_t cmd, uint8_t scmd, uint8_t len, uint8_t *data)
  93:.././simpleserial/simpleserial.c **** {
  94:.././simpleserial/simpleserial.c **** 	uint8_t ver = SS_VER;
  95:.././simpleserial/simpleserial.c **** 	simpleserial_put('r', 1, &ver);
  96:.././simpleserial/simpleserial.c **** 	return SS_ERR_OK;
  97:.././simpleserial/simpleserial.c **** }
  98:.././simpleserial/simpleserial.c **** 
  99:.././simpleserial/simpleserial.c **** uint8_t ss_get_commands(uint8_t cmd, uint8_t scmd, uint8_t len, uint8_t *data)
 100:.././simpleserial/simpleserial.c **** {
 101:.././simpleserial/simpleserial.c ****     uint8_t cmd_chars[MAX_SS_CMDS];
 102:.././simpleserial/simpleserial.c ****     for (uint8_t i = 0; i < (num_commands & 0xFF); i++) {
 103:.././simpleserial/simpleserial.c ****         cmd_chars[i] = commands[i].c;
 104:.././simpleserial/simpleserial.c ****     }
 105:.././simpleserial/simpleserial.c **** 
 106:.././simpleserial/simpleserial.c ****     simpleserial_put('r', num_commands & 0xFF, (void *)cmd_chars);
 107:.././simpleserial/simpleserial.c ****     return 0x00;
 108:.././simpleserial/simpleserial.c **** 
 109:.././simpleserial/simpleserial.c **** }
 110:.././simpleserial/simpleserial.c **** 
 111:.././simpleserial/simpleserial.c **** uint8_t stuff_data(uint8_t *buf, uint8_t len)
 112:.././simpleserial/simpleserial.c **** {
 113:.././simpleserial/simpleserial.c **** 	uint8_t i = 1;
 114:.././simpleserial/simpleserial.c **** 	uint8_t last = 0;
 115:.././simpleserial/simpleserial.c **** 	for (; i < len; i++) {
 116:.././simpleserial/simpleserial.c **** 		if (buf[i] == FRAME_BYTE) {
 117:.././simpleserial/simpleserial.c **** 			buf[last] = i - last;
 118:.././simpleserial/simpleserial.c **** 			last = i;
 119:.././simpleserial/simpleserial.c **** 		}
 120:.././simpleserial/simpleserial.c **** 	}
 121:.././simpleserial/simpleserial.c **** 	return 0x00;
 122:.././simpleserial/simpleserial.c **** }
 123:.././simpleserial/simpleserial.c **** 
 124:.././simpleserial/simpleserial.c **** uint8_t unstuff_data(uint8_t *buf, uint8_t len)
 125:.././simpleserial/simpleserial.c **** {
 126:.././simpleserial/simpleserial.c **** 	uint8_t next = buf[0];
 127:.././simpleserial/simpleserial.c **** 	buf[0] = 0x00;
 128:.././simpleserial/simpleserial.c **** 	//len -= 1;
 129:.././simpleserial/simpleserial.c **** 	uint8_t tmp = next;
 130:.././simpleserial/simpleserial.c **** 	while ((next < len) && tmp != 0) {
 131:.././simpleserial/simpleserial.c **** 		tmp = buf[next];
 132:.././simpleserial/simpleserial.c **** 		buf[next] = FRAME_BYTE;
 133:.././simpleserial/simpleserial.c **** 		next += tmp;
 134:.././simpleserial/simpleserial.c **** 	}
 135:.././simpleserial/simpleserial.c **** 	return next;
 136:.././simpleserial/simpleserial.c **** }
 137:.././simpleserial/simpleserial.c **** 
 138:.././simpleserial/simpleserial.c **** // Set up the SimpleSerial module by preparing internal commands
 139:.././simpleserial/simpleserial.c **** // This just adds the "v" command for now...
 140:.././simpleserial/simpleserial.c **** void simpleserial_init()
 141:.././simpleserial/simpleserial.c **** {
 142:.././simpleserial/simpleserial.c **** 	simpleserial_addcmd('v', 0, check_version);
 143:.././simpleserial/simpleserial.c ****     simpleserial_addcmd('w', 0, ss_get_commands);
 144:.././simpleserial/simpleserial.c **** }
 145:.././simpleserial/simpleserial.c **** 
 146:.././simpleserial/simpleserial.c **** int simpleserial_addcmd(char c, unsigned int len, uint8_t (*fp)(uint8_t, uint8_t, uint8_t, uint8_t*
 147:.././simpleserial/simpleserial.c **** {
 148:.././simpleserial/simpleserial.c **** 	if(num_commands >= MAX_SS_CMDS) {
 149:.././simpleserial/simpleserial.c **** 		putch('a');
 150:.././simpleserial/simpleserial.c **** 		return 1;
 151:.././simpleserial/simpleserial.c **** 	}
 152:.././simpleserial/simpleserial.c **** 
 153:.././simpleserial/simpleserial.c **** 	if(len >= MAX_SS_LEN) {
 154:.././simpleserial/simpleserial.c **** 		putch('b');
 155:.././simpleserial/simpleserial.c **** 		return 1;
 156:.././simpleserial/simpleserial.c **** 	}
 157:.././simpleserial/simpleserial.c **** 
 158:.././simpleserial/simpleserial.c **** 	commands[num_commands].c   = c;
 159:.././simpleserial/simpleserial.c **** 	commands[num_commands].len = len;
 160:.././simpleserial/simpleserial.c **** 	commands[num_commands].fp  = fp;
 161:.././simpleserial/simpleserial.c **** 	num_commands++;
 162:.././simpleserial/simpleserial.c **** 
 163:.././simpleserial/simpleserial.c **** 	return 0;
 164:.././simpleserial/simpleserial.c **** }
 165:.././simpleserial/simpleserial.c **** 
 166:.././simpleserial/simpleserial.c **** void simpleserial_get(void)
 167:.././simpleserial/simpleserial.c **** {
 168:.././simpleserial/simpleserial.c **** 	uint8_t data_buf[MAX_SS_LEN];
 169:.././simpleserial/simpleserial.c **** 	uint8_t err = 0;
 170:.././simpleserial/simpleserial.c **** 
 171:.././simpleserial/simpleserial.c **** 	for (int i = 0; i < 4; i++) {
 172:.././simpleserial/simpleserial.c **** 		data_buf[i] = getch(); //PTR, cmd, scmd, len
 173:.././simpleserial/simpleserial.c **** 		if (data_buf[i] == FRAME_BYTE) {
 174:.././simpleserial/simpleserial.c **** 			err = SS_ERR_FRAME_BYTE;
 175:.././simpleserial/simpleserial.c **** 			goto ERROR;
 176:.././simpleserial/simpleserial.c **** 		}
 177:.././simpleserial/simpleserial.c **** 	}
 178:.././simpleserial/simpleserial.c **** 	uint8_t next_frame = unstuff_data(data_buf, 4);
 179:.././simpleserial/simpleserial.c **** 
 180:.././simpleserial/simpleserial.c **** 	// check for valid command
 181:.././simpleserial/simpleserial.c **** 	uint8_t c = 0;
 182:.././simpleserial/simpleserial.c **** 	for(c = 0; c < num_commands; c++)
 183:.././simpleserial/simpleserial.c **** 	{
 184:.././simpleserial/simpleserial.c **** 		if(commands[c].c == data_buf[1])
 185:.././simpleserial/simpleserial.c **** 			break;
 186:.././simpleserial/simpleserial.c **** 	}
 187:.././simpleserial/simpleserial.c **** 
 188:.././simpleserial/simpleserial.c **** 	if (c == num_commands) {
 189:.././simpleserial/simpleserial.c **** 		err = SS_ERR_CMD;
 190:.././simpleserial/simpleserial.c **** 		goto ERROR;
 191:.././simpleserial/simpleserial.c **** 	}
 192:.././simpleserial/simpleserial.c **** 
 193:.././simpleserial/simpleserial.c **** 	//check that next frame not beyond end of message
 194:.././simpleserial/simpleserial.c **** 	// account for cmd, scmd, len, data, crc, end of frame
 195:.././simpleserial/simpleserial.c **** 	if ((data_buf[3] + 5) < next_frame) {
 196:.././simpleserial/simpleserial.c **** 		err = SS_ERR_LEN;
 197:.././simpleserial/simpleserial.c **** 		goto ERROR;
 198:.././simpleserial/simpleserial.c **** 	}
 199:.././simpleserial/simpleserial.c **** 
 200:.././simpleserial/simpleserial.c **** 	// read in data
 201:.././simpleserial/simpleserial.c **** 	// eq to len + crc + frame end
 202:.././simpleserial/simpleserial.c **** 	int i = 4;
 203:.././simpleserial/simpleserial.c **** 	for (; i < data_buf[3] + 5; i++) {
 204:.././simpleserial/simpleserial.c **** 		data_buf[i] = getch();
 205:.././simpleserial/simpleserial.c **** 		if (data_buf[i] == FRAME_BYTE) {
 206:.././simpleserial/simpleserial.c **** 			err = SS_ERR_FRAME_BYTE;
 207:.././simpleserial/simpleserial.c **** 			goto ERROR;
 208:.././simpleserial/simpleserial.c **** 		}
 209:.././simpleserial/simpleserial.c **** 	}
 210:.././simpleserial/simpleserial.c **** 
 211:.././simpleserial/simpleserial.c **** 	//check that final byte is the FRAME_BYTE
 212:.././simpleserial/simpleserial.c **** 	data_buf[i] = getch();
 213:.././simpleserial/simpleserial.c **** 	if (data_buf[i] != FRAME_BYTE) {
 214:.././simpleserial/simpleserial.c **** 		err = SS_ERR_LEN;
 215:.././simpleserial/simpleserial.c **** 		goto ERROR;
 216:.././simpleserial/simpleserial.c **** 	}
 217:.././simpleserial/simpleserial.c **** 
 218:.././simpleserial/simpleserial.c **** 	//fully unstuff data now
 219:.././simpleserial/simpleserial.c **** 	unstuff_data(data_buf + next_frame, i - next_frame + 1);
 220:.././simpleserial/simpleserial.c **** 
 221:.././simpleserial/simpleserial.c **** 	//calc crc excluding original frame offset and frame end and crc
 222:.././simpleserial/simpleserial.c **** 	uint8_t crc = ss_crc(data_buf+1, i-2);
 223:.././simpleserial/simpleserial.c **** 	if (crc != data_buf[i-1]) {
 224:.././simpleserial/simpleserial.c **** 		err = SS_ERR_CRC;
 225:.././simpleserial/simpleserial.c **** 		goto ERROR;
 226:.././simpleserial/simpleserial.c **** 	}
 227:.././simpleserial/simpleserial.c **** 
 228:.././simpleserial/simpleserial.c **** 	err = commands[c].fp(data_buf[1], data_buf[2], data_buf[3], data_buf+4);
 229:.././simpleserial/simpleserial.c **** 
 230:.././simpleserial/simpleserial.c **** ERROR:
 231:.././simpleserial/simpleserial.c **** 	simpleserial_put('e', 0x01, &err);
 232:.././simpleserial/simpleserial.c **** 	return;
 233:.././simpleserial/simpleserial.c **** }
 234:.././simpleserial/simpleserial.c **** 
 235:.././simpleserial/simpleserial.c **** void simpleserial_put(char c, uint8_t size, uint8_t* output)
 236:.././simpleserial/simpleserial.c **** {
 237:.././simpleserial/simpleserial.c ****     if (!output) return;
 238:.././simpleserial/simpleserial.c **** 	uint8_t data_buf[MAX_SS_LEN+5];
 239:.././simpleserial/simpleserial.c **** 	data_buf[0] = 0x00;
 240:.././simpleserial/simpleserial.c **** 	data_buf[1] = c;
 241:.././simpleserial/simpleserial.c **** 	data_buf[2] = size;
 242:.././simpleserial/simpleserial.c **** 	int i = 0;
 243:.././simpleserial/simpleserial.c **** 	for (; i < size; i++) {
 244:.././simpleserial/simpleserial.c **** 		data_buf[i + 3] = output[i];
 245:.././simpleserial/simpleserial.c **** 	}
 246:.././simpleserial/simpleserial.c **** 	data_buf[i + 3] = ss_crc(data_buf+1, size+2);
 247:.././simpleserial/simpleserial.c **** 	data_buf[i + 4] = 0x00;
 248:.././simpleserial/simpleserial.c **** 	stuff_data(data_buf, i + 5);
 249:.././simpleserial/simpleserial.c **** 	for (int i = 0; i < size + 5; i++) {
 250:.././simpleserial/simpleserial.c **** 		putch(data_buf[i]);
 251:.././simpleserial/simpleserial.c **** 	}
 252:.././simpleserial/simpleserial.c **** }
 253:.././simpleserial/simpleserial.c **** 
 254:.././simpleserial/simpleserial.c **** 
 255:.././simpleserial/simpleserial.c **** #else
 256:.././simpleserial/simpleserial.c **** 
 257:.././simpleserial/simpleserial.c **** #ifndef MAX_SS_LEN
 258:.././simpleserial/simpleserial.c **** #define MAX_SS_LEN 64
 259:.././simpleserial/simpleserial.c **** #endif
 260:.././simpleserial/simpleserial.c **** 
