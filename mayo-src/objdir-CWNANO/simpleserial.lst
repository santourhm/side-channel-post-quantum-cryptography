 289:.././simpleserial/simpleserial.c **** uint8_t ss_get_commands(uint8_t *x, uint8_t len)
 290:.././simpleserial/simpleserial.c **** {
 291:.././simpleserial/simpleserial.c ****     ss_cmd_repr repr_cmd_buf[MAX_SS_CMDS];
 292:.././simpleserial/simpleserial.c ****     for (uint8_t i = 0; i < (num_commands & 0xFF); i++) {
 293:.././simpleserial/simpleserial.c ****         repr_cmd_buf[i].c = commands[i].c;
 294:.././simpleserial/simpleserial.c ****         repr_cmd_buf[i].len = commands[i].len;
 295:.././simpleserial/simpleserial.c ****         repr_cmd_buf[i].flags = commands[i].flags;
 296:.././simpleserial/simpleserial.c ****     }
 297:.././simpleserial/simpleserial.c **** 
 298:.././simpleserial/simpleserial.c ****     simpleserial_put('r', num_commands * sizeof (ss_cmd_repr), (void *) repr_cmd_buf);
 299:.././simpleserial/simpleserial.c ****     return 0x00;
 300:.././simpleserial/simpleserial.c **** }
 301:.././simpleserial/simpleserial.c **** 
 302:.././simpleserial/simpleserial.c **** static char hex_lookup[16] =
 303:.././simpleserial/simpleserial.c **** {
 304:.././simpleserial/simpleserial.c **** 	'0', '1', '2', '3', '4', '5', '6', '7',
 305:.././simpleserial/simpleserial.c **** 	'8', '9', 'A', 'B', 'C', 'D', 'E', 'F'
 306:.././simpleserial/simpleserial.c **** };
 307:.././simpleserial/simpleserial.c **** 
 308:.././simpleserial/simpleserial.c **** int hex_decode(int len, char* ascii_buf, uint8_t* data_buf)
 309:.././simpleserial/simpleserial.c **** {
 310:.././simpleserial/simpleserial.c **** 	for(int i = 0; i < len; i++)
 311:.././simpleserial/simpleserial.c **** 	{
 312:.././simpleserial/simpleserial.c **** 		char n_hi = ascii_buf[2*i];
 313:.././simpleserial/simpleserial.c **** 		char n_lo = ascii_buf[2*i+1];
 314:.././simpleserial/simpleserial.c **** 
 315:.././simpleserial/simpleserial.c **** 		if(n_lo >= '0' && n_lo <= '9')
 316:.././simpleserial/simpleserial.c **** 			data_buf[i] = n_lo - '0';
 317:.././simpleserial/simpleserial.c **** 		else if(n_lo >= 'A' && n_lo <= 'F')
 318:.././simpleserial/simpleserial.c **** 			data_buf[i] = n_lo - 'A' + 10;
 319:.././simpleserial/simpleserial.c **** 		else if(n_lo >= 'a' && n_lo <= 'f')
 320:.././simpleserial/simpleserial.c **** 			data_buf[i] = n_lo - 'a' + 10;
 321:.././simpleserial/simpleserial.c **** 		else
 322:.././simpleserial/simpleserial.c **** 			return 1;
 323:.././simpleserial/simpleserial.c **** 
 324:.././simpleserial/simpleserial.c **** 		if(n_hi >= '0' && n_hi <= '9')
 325:.././simpleserial/simpleserial.c **** 			data_buf[i] |= (n_hi - '0') << 4;
 326:.././simpleserial/simpleserial.c **** 		else if(n_hi >= 'A' && n_hi <= 'F')
 327:.././simpleserial/simpleserial.c **** 			data_buf[i] |= (n_hi - 'A' + 10) << 4;
 328:.././simpleserial/simpleserial.c **** 		else if(n_hi >= 'a' && n_hi <= 'f')
 329:.././simpleserial/simpleserial.c **** 			data_buf[i] |= (n_hi - 'a' + 10) << 4;
 330:.././simpleserial/simpleserial.c **** 		else
 331:.././simpleserial/simpleserial.c **** 			return 1;
 332:.././simpleserial/simpleserial.c **** 	}
 333:.././simpleserial/simpleserial.c **** 
 334:.././simpleserial/simpleserial.c **** 	return 0;
 335:.././simpleserial/simpleserial.c **** }
 336:.././simpleserial/simpleserial.c **** 
 337:.././simpleserial/simpleserial.c **** 
 338:.././simpleserial/simpleserial.c **** 
 339:.././simpleserial/simpleserial.c **** // Set up the SimpleSerial module by preparing internal commands
 340:.././simpleserial/simpleserial.c **** // This just adds the "v" command for now...
 341:.././simpleserial/simpleserial.c **** void simpleserial_init()
 342:.././simpleserial/simpleserial.c **** {
 343:.././simpleserial/simpleserial.c **** 	simpleserial_addcmd('v', 0, check_version);
 344:.././simpleserial/simpleserial.c ****     simpleserial_addcmd('w', 0, ss_get_commands);
 345:.././simpleserial/simpleserial.c ****     simpleserial_addcmd('y', 0, ss_num_commands);
 346:.././simpleserial/simpleserial.c **** }
 347:.././simpleserial/simpleserial.c **** 
 348:.././simpleserial/simpleserial.c **** int simpleserial_addcmd(char c, unsigned int len, uint8_t (*fp)(uint8_t*, uint8_t))
 349:.././simpleserial/simpleserial.c **** {
 350:.././simpleserial/simpleserial.c **** 	return simpleserial_addcmd_flags(c, len, fp, CMD_FLAG_NONE);
 351:.././simpleserial/simpleserial.c **** }
 352:.././simpleserial/simpleserial.c **** 
 353:.././simpleserial/simpleserial.c **** int simpleserial_addcmd_flags(char c, unsigned int len, uint8_t (*fp)(uint8_t*, uint8_t), uint8_t f
 354:.././simpleserial/simpleserial.c **** {
 355:.././simpleserial/simpleserial.c **** 	if(num_commands >= MAX_SS_CMDS)
 356:.././simpleserial/simpleserial.c **** 		return 1;
 357:.././simpleserial/simpleserial.c **** 
 358:.././simpleserial/simpleserial.c **** 	if(len >= MAX_SS_LEN)
 359:.././simpleserial/simpleserial.c **** 		return 1;
 360:.././simpleserial/simpleserial.c **** 
 361:.././simpleserial/simpleserial.c **** 	commands[num_commands].c   = c;
 362:.././simpleserial/simpleserial.c **** 	commands[num_commands].len = len;
 363:.././simpleserial/simpleserial.c **** 	commands[num_commands].fp  = fp;
 364:.././simpleserial/simpleserial.c **** 	commands[num_commands].flags = fl;
 365:.././simpleserial/simpleserial.c **** 	num_commands++;
 366:.././simpleserial/simpleserial.c **** 
 367:.././simpleserial/simpleserial.c **** 	return 0;
 368:.././simpleserial/simpleserial.c **** }
 369:.././simpleserial/simpleserial.c **** 
 370:.././simpleserial/simpleserial.c **** void simpleserial_get(void)
 371:.././simpleserial/simpleserial.c **** {
 372:.././simpleserial/simpleserial.c **** 	char ascii_buf[2*MAX_SS_LEN];
 373:.././simpleserial/simpleserial.c **** 	uint8_t data_buf[MAX_SS_LEN];
 374:.././simpleserial/simpleserial.c **** 	char c;
 375:.././simpleserial/simpleserial.c **** 
 376:.././simpleserial/simpleserial.c **** 	// Find which command we're receiving
 377:.././simpleserial/simpleserial.c **** 	c = getch();
 378:.././simpleserial/simpleserial.c **** 
 379:.././simpleserial/simpleserial.c **** 	int cmd;
 380:.././simpleserial/simpleserial.c **** 	for(cmd = 0; cmd < num_commands; cmd++)
 381:.././simpleserial/simpleserial.c **** 	{
 382:.././simpleserial/simpleserial.c **** 		if(commands[cmd].c == c)
 383:.././simpleserial/simpleserial.c **** 			break;
 384:.././simpleserial/simpleserial.c **** 	}
 385:.././simpleserial/simpleserial.c **** 
 386:.././simpleserial/simpleserial.c **** 	// If we didn't find a match, give up right away
 387:.././simpleserial/simpleserial.c **** 	if(cmd == num_commands)
 388:.././simpleserial/simpleserial.c **** 		return;
 389:.././simpleserial/simpleserial.c **** 
 390:.././simpleserial/simpleserial.c **** 	// If flag CMD_FLAG_LEN is set, the next byte indicates the sent length
 391:.././simpleserial/simpleserial.c **** 	if ((commands[cmd].flags & CMD_FLAG_LEN) != 0)
 392:.././simpleserial/simpleserial.c **** 	{
 393:.././simpleserial/simpleserial.c **** 		uint8_t l = 0;
 394:.././simpleserial/simpleserial.c **** 		char buff[2];
 395:.././simpleserial/simpleserial.c **** 		buff[0] = getch();
 396:.././simpleserial/simpleserial.c **** 		buff[1] = getch();
 397:.././simpleserial/simpleserial.c **** 		if (hex_decode(1, buff, &l))
 398:.././simpleserial/simpleserial.c **** 			return;
 399:.././simpleserial/simpleserial.c **** 		commands[cmd].len = l;
 400:.././simpleserial/simpleserial.c **** 	}
 401:.././simpleserial/simpleserial.c **** 
 402:.././simpleserial/simpleserial.c **** 	// Receive characters until we fill the ASCII buffer
 403:.././simpleserial/simpleserial.c **** 	for(int i = 0; i < 2*commands[cmd].len; i++)
 404:.././simpleserial/simpleserial.c **** 	{
 405:.././simpleserial/simpleserial.c **** 		c = getch();
 406:.././simpleserial/simpleserial.c **** 
 407:.././simpleserial/simpleserial.c **** 		// Check for early \n
 408:.././simpleserial/simpleserial.c **** 		if(c == '\n' || c == '\r')
 409:.././simpleserial/simpleserial.c **** 			return;
 410:.././simpleserial/simpleserial.c **** 
 411:.././simpleserial/simpleserial.c **** 		ascii_buf[i] = c;
 412:.././simpleserial/simpleserial.c **** 	}
 413:.././simpleserial/simpleserial.c **** 
 414:.././simpleserial/simpleserial.c **** 	// Assert that last character is \n or \r
 415:.././simpleserial/simpleserial.c **** 	c = getch();
 416:.././simpleserial/simpleserial.c **** 	if(c != '\n' && c != '\r')
 417:.././simpleserial/simpleserial.c **** 		return;
 418:.././simpleserial/simpleserial.c **** 
 419:.././simpleserial/simpleserial.c **** 	// ASCII buffer is full: convert to bytes
 420:.././simpleserial/simpleserial.c **** 	// Check for illegal characters here
 421:.././simpleserial/simpleserial.c **** 	if(hex_decode(commands[cmd].len, ascii_buf, data_buf))
 422:.././simpleserial/simpleserial.c **** 		return;
 423:.././simpleserial/simpleserial.c **** 
 424:.././simpleserial/simpleserial.c **** 	// Callback
 425:.././simpleserial/simpleserial.c **** 	uint8_t ret[1];
 426:.././simpleserial/simpleserial.c **** 	ret[0] = commands[cmd].fp(data_buf, commands[cmd].len);
 427:.././simpleserial/simpleserial.c **** 
 428:.././simpleserial/simpleserial.c **** 	// Acknowledge (if version is 1.1)
 429:.././simpleserial/simpleserial.c **** #if SS_VER == SS_VER_1_1
 430:.././simpleserial/simpleserial.c **** 	simpleserial_put('z', 1, ret);
 431:.././simpleserial/simpleserial.c **** #endif
 432:.././simpleserial/simpleserial.c **** }
 433:.././simpleserial/simpleserial.c **** 
