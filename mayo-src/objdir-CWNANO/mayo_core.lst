  33:mayo_core.c   **** /*  Global RAM buffers (all in .bss, counted against 4 KB budget)     */
  34:mayo_core.c   **** /* ================================================================== */
  35:mayo_core.c   **** 
  36:mayo_core.c   **** uint8_t g_mayo_esk[MAYO_ESK_B];          /* 576 B: seedsk|seedpk|O|L  */
  37:mayo_core.c   **** 
  38:mayo_core.c   **** /* Work buffers shared between calls — large enough for signing */
  39:mayo_core.c   **** static uint8_t g_A[MAYO_M * MAYO_KO / 2];  /* 160 B: system matrix A   */
  40:mayo_core.c   **** static uint8_t g_Mi[MAYO_K][MAYO_M * MAYO_O / 2]; /* 160 B: all Mi     */
  41:mayo_core.c   **** 
  42:mayo_core.c   **** /* ================================================================== */
  43:mayo_core.c   **** /*  Key expansion: mayo_expand_sk()                                    */
  44:mayo_core.c   **** /* ================================================================== */
  45:mayo_core.c   **** 
  46:mayo_core.c   **** void mayo_expand_sk(const uint8_t seedsk[MAYO_SKSEED_B])
  47:mayo_core.c   **** {
  48:mayo_core.c   ****     uint8_t  shake_out[MAYO_PKSEED_B + MAYO_O_B]; /* 48 bytes on stack */
  49:mayo_core.c   ****     uint8_t  decoded[16];                           /* one bitsliced pos */
  50:mayo_core.c   ****     uint8_t  bs8[8];                                /* one bitsliced vec  */
  51:mayo_core.c   ****     int r, s, d, a;
  52:mayo_core.c   **** 
  53:mayo_core.c   ****     /* --- 1. SHAKE256(seedsk) → seedpk (16B) || O_encoded (32B) --- */
  54:mayo_core.c   ****     shake256_multi(seedsk, MAYO_SKSEED_B,
  55:mayo_core.c   ****                    NULL, 0, NULL, 0, NULL, 0,
  56:mayo_core.c   ****                    shake_out, sizeof(shake_out));
  57:mayo_core.c   **** 
  58:mayo_core.c   ****     /* Store seedsk, seedpk, O into ESK */
  59:mayo_core.c   ****     memcpy(g_mayo_esk + MAYO_ESK_SEEDSK_OFF, seedsk,          MAYO_SKSEED_B);
  60:mayo_core.c   ****     memcpy(g_mayo_esk + MAYO_ESK_SEEDPK_OFF, shake_out,       MAYO_PKSEED_B);
  61:mayo_core.c   ****     memcpy(g_mayo_esk + MAYO_ESK_O_OFF,      shake_out + MAYO_PKSEED_B, MAYO_O_B);
  62:mayo_core.c   **** 
  63:mayo_core.c   ****     /* --- 2. Zero L --- */
  64:mayo_core.c   ****     memset(g_mayo_esk + MAYO_ESK_L_OFF, 0, MAYO_L_B);
  65:mayo_core.c   **** 
  66:mayo_core.c   ****     /* --- 3. SHAKE256(seedpk) stream: compute L = (P1+P1^T)*O + P2 --- */
  67:mayo_core.c   ****     shake256_init(&g_shake);
  68:mayo_core.c   ****     shake256_absorb(&g_shake, shake_out /* seedpk */, MAYO_PKSEED_B);
  69:mayo_core.c   ****     shake256_finalize(&g_shake);
  70:mayo_core.c   **** 
  71:mayo_core.c   ****     /* P1: upper-triangular positions (r, s) with r <= s, r in [V], s in [V] */
  72:mayo_core.c   ****     for (r = 0; r < MAYO_V; r++) {
  73:mayo_core.c   ****         for (s = r; s < MAYO_V; s++) {
  74:mayo_core.c   ****             shake256_squeeze(&g_shake, bs8, 8);
  75:mayo_core.c   ****             if (r == s) continue; /* diagonal: (P1+P1^T)[r,r] = 2*P1[r,r] = 0 */
  76:mayo_core.c   **** 
  77:mayo_core.c   ****             decode_bs8(bs8, decoded); /* decoded[a] = P1_a[r,s] for a in [M] */
  78:mayo_core.c   **** 
  79:mayo_core.c   ****             for (d = 0; d < MAYO_O; d++) {
  80:mayo_core.c   ****                 uint8_t O_s_d = nibble_get(g_mayo_esk + MAYO_ESK_O_OFF, s * MAYO_O + d);
  81:mayo_core.c   ****                 uint8_t O_r_d = nibble_get(g_mayo_esk + MAYO_ESK_O_OFF, r * MAYO_O + d);
  82:mayo_core.c   ****                 for (a = 0; a < MAYO_M; a++) {
  83:mayo_core.c   ****                     /* L[r,d,a] ^= P1_a[r,s] * O[s,d]  (upper part of P1+P1^T) */
  84:mayo_core.c   ****                     nibble_add(g_mayo_esk + MAYO_ESK_L_OFF,
  85:mayo_core.c   ****                                (r * MAYO_O + d) * MAYO_M + a,
  86:mayo_core.c   ****                                gf16_mul(decoded[a], O_s_d));
  87:mayo_core.c   ****                     /* L[s,d,a] ^= P1_a[r,s] * O[r,d]  (lower part of P1+P1^T) */
  88:mayo_core.c   ****                     nibble_add(g_mayo_esk + MAYO_ESK_L_OFF,
  89:mayo_core.c   ****                                (s * MAYO_O + d) * MAYO_M + a,
  90:mayo_core.c   ****                                gf16_mul(decoded[a], O_r_d));
  91:mayo_core.c   ****                 }
  92:mayo_core.c   ****             }
  93:mayo_core.c   ****         }
  94:mayo_core.c   ****     }
  95:mayo_core.c   **** 
  96:mayo_core.c   ****     /* P2: all (r, d) positions, r in [V], d in [O] */
  97:mayo_core.c   ****     for (r = 0; r < MAYO_V; r++) {
  98:mayo_core.c   ****         for (d = 0; d < MAYO_O; d++) {
  99:mayo_core.c   ****             shake256_squeeze(&g_shake, bs8, 8);
 100:mayo_core.c   ****             decode_bs8(bs8, decoded); /* decoded[a] = P2_a[r,d] */
 101:mayo_core.c   ****             for (a = 0; a < MAYO_M; a++) {
 102:mayo_core.c   ****                 nibble_add(g_mayo_esk + MAYO_ESK_L_OFF,
 103:mayo_core.c   ****                            (r * MAYO_O + d) * MAYO_M + a,
 104:mayo_core.c   ****                            decoded[a]);
 105:mayo_core.c   ****             }
 106:mayo_core.c   ****         }
 107:mayo_core.c   ****     }
 108:mayo_core.c   **** }
