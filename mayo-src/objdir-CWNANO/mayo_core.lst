 450:mayo_core.c   ****                     /* oil vars for this block: x[i*O .. (i+1)*O - 1] */
 451:mayo_core.c   ****                     for (eq = 0; eq < MAYO_N; eq++) {
 452:mayo_core.c   ****                         uint8_t s_eq;
 453:mayo_core.c   ****                         if (eq < MAYO_V) {
 454:mayo_core.c   ****                             /* vinegar part: vi[eq] + (O*xi)[eq] */
 455:mayo_core.c   ****                             s_eq = nibble_get(V_buf + i * MAYO_V_B, eq);
 456:mayo_core.c   ****                             for (d = 0; d < MAYO_O; d++) {
 457:mayo_core.c   ****                                 uint8_t xi_d = nibble_get(x, i * MAYO_O + d);
 458:mayo_core.c   ****                                 s_eq ^= gf16_mul(nibble_get(O, eq * MAYO_O + d),
 459:mayo_core.c   ****                                                  xi_d);
 460:mayo_core.c   ****                             }
 461:mayo_core.c   ****                         } else {
 462:mayo_core.c   ****                             /* oil part: xi[eq - V] */
 463:mayo_core.c   ****                             s_eq = nibble_get(x, i * MAYO_O + (eq - MAYO_V));
 464:mayo_core.c   ****                         }
 465:mayo_core.c   ****                         /* Write s_eq into sig at nibble index i*N + eq */
 466:mayo_core.c   ****                         nibble_add(sig, i * MAYO_N + eq, s_eq);
 467:mayo_core.c   ****                     }
 468:mayo_core.c   ****                 }
 469:mayo_core.c   **** 
