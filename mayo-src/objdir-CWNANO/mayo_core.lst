 162:mayo_core.c   **** 
 163:mayo_core.c   **** /*
 164:mayo_core.c   ****  * Gaussian elimination over GF(16): put (A | y) in row-echelon form.
 165:mayo_core.c   ****  * A:   m x ko  nibble array (modified in-place)
 166:mayo_core.c   ****  * aug: m       nibble array (the augmented column, modified in-place)
 167:mayo_core.c   ****  * Returns the pivot rank (should be MAYO_M for a full-rank system).
 168:mayo_core.c   ****  */
 169:mayo_core.c   **** static int gauss_elim(uint8_t *A, uint8_t *aug)
 170:mayo_core.c   **** {
 171:mayo_core.c   ****     int pr = 0, pc = 0; /* pivot row, pivot column */
 172:mayo_core.c   ****     int i, c;
 173:mayo_core.c   **** 
 174:mayo_core.c   ****     while (pr < MAYO_M && pc < MAYO_KO) {
 175:mayo_core.c   ****         /* Find pivot in column pc from row pr downward */
 176:mayo_core.c   ****         int next = -1;
 177:mayo_core.c   ****         for (i = pr; i < MAYO_M; i++) {
 178:mayo_core.c   ****             if (nibble_get(A, i * MAYO_KO + pc) != 0) { next = i; break; }
 179:mayo_core.c   ****         }
 180:mayo_core.c   ****         if (next < 0) { pc++; continue; }
 181:mayo_core.c   **** 
 182:mayo_core.c   ****         /* Swap rows pr and next */
 183:mayo_core.c   ****         if (next != pr) {
 184:mayo_core.c   ****             for (c = 0; c < MAYO_KO; c++) {
 185:mayo_core.c   ****                 uint8_t tmp = nibble_get(A, pr * MAYO_KO + c);
 186:mayo_core.c   ****                 nibble_set(A, pr * MAYO_KO + c,
 187:mayo_core.c   ****                            nibble_get(A, next * MAYO_KO + c));
 188:mayo_core.c   ****                 nibble_set(A, next * MAYO_KO + c, tmp);
 189:mayo_core.c   ****             }
 190:mayo_core.c   ****             uint8_t tmp = nibble_get(aug, pr);
 191:mayo_core.c   ****             nibble_set(aug, pr, nibble_get(aug, next));
 192:mayo_core.c   ****             nibble_set(aug, next, tmp);
 193:mayo_core.c   ****         }
 194:mayo_core.c   **** 
 195:mayo_core.c   ****         /* Scale pivot row so leading entry = 1 */
 196:mayo_core.c   ****         uint8_t piv = nibble_get(A, pr * MAYO_KO + pc);
 197:mayo_core.c   ****         uint8_t inv = gf16_inv(piv);
 198:mayo_core.c   ****         for (c = pc; c < MAYO_KO; c++) {
 199:mayo_core.c   ****             nibble_set(A, pr * MAYO_KO + c,
 200:mayo_core.c   ****                        gf16_mul(nibble_get(A, pr * MAYO_KO + c), inv));
 201:mayo_core.c   ****         }
 202:mayo_core.c   ****         nibble_set(aug, pr, gf16_mul(nibble_get(aug, pr), inv));
 203:mayo_core.c   **** 
 204:mayo_core.c   ****         /* Eliminate all other rows in column pc */
 205:mayo_core.c   ****         for (i = 0; i < MAYO_M; i++) {
 206:mayo_core.c   ****             if (i == pr) continue;
 207:mayo_core.c   ****             uint8_t factor = nibble_get(A, i * MAYO_KO + pc);
 208:mayo_core.c   ****             if (factor == 0) continue;
 209:mayo_core.c   ****             for (c = pc; c < MAYO_KO; c++) {
 210:mayo_core.c   ****                 nibble_add(A, i * MAYO_KO + c,
 211:mayo_core.c   ****                            gf16_mul(factor, nibble_get(A, pr * MAYO_KO + c)));
 212:mayo_core.c   ****             }
 213:mayo_core.c   ****             nibble_add(aug, i, gf16_mul(factor, nibble_get(aug, pr)));
 214:mayo_core.c   ****         }
 215:mayo_core.c   **** 
 216:mayo_core.c   ****         pr++; pc++;
 217:mayo_core.c   ****     }
 218:mayo_core.c   ****     return pr;
 219:mayo_core.c   **** }
 220:mayo_core.c   **** 
 221:mayo_core.c   **** /*
 222:mayo_core.c   ****  * SampleSolution: given system A*x = y and randomness r,
 223:mayo_core.c   ****  * find x = r + particular_solution.
 224:mayo_core.c   ****  * x_out: ko nibbles.  Returns 0 on success, -1 if rank < m.
 225:mayo_core.c   ****  */
 226:mayo_core.c   **** static int sample_solution(uint8_t *x_out,
 227:mayo_core.c   ****                             const uint8_t *r_nibbles,
 228:mayo_core.c   ****                             uint8_t *A,   /* modified in-place */
 229:mayo_core.c   ****                             uint8_t *y)   /* modified in-place */
 230:mayo_core.c   **** {
 231:mayo_core.c   ****     int col, eq;
 232:mayo_core.c   **** 
 233:mayo_core.c   ****     /* x ← r */
 234:mayo_core.c   ****     memcpy(x_out, r_nibbles, (MAYO_KO + 1) / 2);
 235:mayo_core.c   **** 
 236:mayo_core.c   ****     /* y ← y - A*r */
 237:mayo_core.c   ****     for (eq = 0; eq < MAYO_M; eq++) {
 238:mayo_core.c   ****         uint8_t t = 0;
 239:mayo_core.c   ****         for (col = 0; col < MAYO_KO; col++)
 240:mayo_core.c   ****             t ^= gf16_mul(nibble_get(A, eq * MAYO_KO + col),
 241:mayo_core.c   ****                           nibble_get(r_nibbles, col));
 242:mayo_core.c   ****         nibble_add(y, eq, t);
 243:mayo_core.c   ****     }
 244:mayo_core.c   **** 
 245:mayo_core.c   ****     /* Row-reduce (A | y) */
 246:mayo_core.c   ****     int rank = gauss_elim(A, y);
 247:mayo_core.c   ****     if (rank < MAYO_M) return -1;
 248:mayo_core.c   **** 
 249:mayo_core.c   ****     /* Back-substitute: for each leading-1 row, read off free variable */
 250:mayo_core.c   ****     /* After full RREF the pivot columns hold the solution directly    */
 251:mayo_core.c   ****     for (eq = 0; eq < MAYO_M; eq++) {
 252:mayo_core.c   ****         /* find pivot column of row eq */
 253:mayo_core.c   ****         for (col = 0; col < MAYO_KO; col++) {
 254:mayo_core.c   ****             if (nibble_get(A, eq * MAYO_KO + col) == 1) {
 255:mayo_core.c   ****                 /* check it's really a pivot (all others in col are 0) */
 256:mayo_core.c   ****                 int is_pivot = 1;
 257:mayo_core.c   ****                 int i;
 258:mayo_core.c   ****                 for (i = 0; i < MAYO_M; i++) {
 259:mayo_core.c   ****                     if (i != eq && nibble_get(A, i * MAYO_KO + col) != 0) {
 260:mayo_core.c   ****                         is_pivot = 0; break;
 261:mayo_core.c   ****                     }
 262:mayo_core.c   ****                 }
 263:mayo_core.c   ****                 if (is_pivot) {
 264:mayo_core.c   ****                     nibble_add(x_out, col, nibble_get(y, eq));
 265:mayo_core.c   ****                     break;
 266:mayo_core.c   ****                 }
 267:mayo_core.c   ****             }
 268:mayo_core.c   ****         }
 269:mayo_core.c   ****     }
 270:mayo_core.c   **** 
 271:mayo_core.c   ****     return 0;
 272:mayo_core.c   **** }
