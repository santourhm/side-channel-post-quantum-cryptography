   7:mayo_gf16.h   **** /*
   8:mayo_gf16.h   ****  * GF(16) = GF(2^4)  with irreducible polynomial  x^4 + x + 1.
   9:mayo_gf16.h   ****  * Elements: 4-bit nibbles 0x0 .. 0xF.
  10:mayo_gf16.h   ****  * Addition: bitwise XOR (characteristic 2).
  11:mayo_gf16.h   ****  * Multiplication: lookup table (256 bytes in flash).
  12:mayo_gf16.h   ****  */
  13:mayo_gf16.h   **** 
