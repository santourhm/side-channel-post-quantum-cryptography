  22:mayo_gf16.h   **** static inline uint8_t gf16_add(uint8_t a, uint8_t b)
  23:mayo_gf16.h   **** {
  24:mayo_gf16.h   ****     return (a ^ b) & 0xF;
  25:mayo_gf16.h   **** }
  26:mayo_gf16.h   **** 
  27:mayo_gf16.h   **** /* a^(q-2) = a^14 via repeated squaring  (q=16) */
  28:mayo_gf16.h   **** static inline uint8_t gf16_inv(uint8_t a)
  29:mayo_gf16.h   **** {
  30:mayo_gf16.h   ****     if (a == 0) return 0;
  31:mayo_gf16.h   ****     uint8_t a2  = gf16_mul(a,  a);
  32:mayo_gf16.h   ****     uint8_t a4  = gf16_mul(a2, a2);
  33:mayo_gf16.h   ****     uint8_t a8  = gf16_mul(a4, a4);
  34:mayo_gf16.h   ****     uint8_t a12 = gf16_mul(a8, a4);
  35:mayo_gf16.h   ****     return            gf16_mul(a12, a2);   /* a^14 */
  36:mayo_gf16.h   **** }
