 113:mayo_core.c   **** 
 114:mayo_core.c   **** /*
 115:mayo_core.c   ****  * Compute Mi[eq*O + d] = sum_r  vi[r] * L[r,d,eq]
 116:mayo_core.c   ****  * Mi and vi are nibble-packed arrays.
 117:mayo_core.c   ****  */
 118:mayo_core.c   **** static void compute_Mi(uint8_t *Mi, const uint8_t *vi, const uint8_t *L)
 119:mayo_core.c   **** {
 120:mayo_core.c   ****     int r, d, eq;
 121:mayo_core.c   ****     memset(Mi, 0, MAYO_M * MAYO_O / 2);
 122:mayo_core.c   ****     for (r = 0; r < MAYO_V; r++) {
 123:mayo_core.c   ****         uint8_t vr = nibble_get(vi, r);
 124:mayo_core.c   ****         if (vr == 0) continue;
 125:mayo_core.c   ****         for (d = 0; d < MAYO_O; d++) {
 126:mayo_core.c   ****             for (eq = 0; eq < MAYO_M; eq++) {
 127:mayo_core.c   ****                 uint8_t l_val = nibble_get(L, (r * MAYO_O + d) * MAYO_M + eq);
 128:mayo_core.c   ****                 nibble_add(Mi, eq * MAYO_O + d, gf16_mul(vr, l_val));
 129:mayo_core.c   ****             }
 130:mayo_core.c   ****         }
 131:mayo_core.c   ****     }
 132:mayo_core.c   **** }
 133:mayo_core.c   **** 
 134:mayo_core.c   **** /*
 135:mayo_core.c   ****  * y[eq] ^= (E^ell * u)[eq]  where E^ell is cyclic right rotation by ell.
 136:mayo_core.c   ****  * (E^ell * u)_eq = u[(eq - ell + M) % M]
 137:mayo_core.c   ****  */
 138:mayo_core.c   **** static void subtract_El_u(uint8_t *y, const uint8_t *u, int ell)
 139:mayo_core.c   **** {
 140:mayo_core.c   ****     int eq;
 141:mayo_core.c   ****     for (eq = 0; eq < MAYO_M; eq++) {
 142:mayo_core.c   ****         int src = (eq - ell + MAYO_M) % MAYO_M;
 143:mayo_core.c   ****         nibble_add(y, eq, nibble_get(u, src));
 144:mayo_core.c   ****     }
 145:mayo_core.c   **** }
 146:mayo_core.c   **** 
 147:mayo_core.c   **** /*
 148:mayo_core.c   ****  * A[:, block*O : (block+1)*O] ^= E^ell * M
 149:mayo_core.c   ****  * (E^ell * M)_{eq, d} = M_{(eq-ell+M)%M, d}
 150:mayo_core.c   ****  */
