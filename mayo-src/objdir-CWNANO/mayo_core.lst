  51:mayo_gf16.h   **** static inline void nibble_set(uint8_t *arr, int idx, uint8_t val)
  52:mayo_gf16.h   **** {
  53:mayo_gf16.h   ****     if (idx & 1)
  54:mayo_gf16.h   ****         arr[idx >> 1] = (arr[idx >> 1] & 0x0F) | ((val & 0xF) << 4);
  55:mayo_gf16.h   ****     else
  56:mayo_gf16.h   ****         arr[idx >> 1] = (arr[idx >> 1] & 0xF0) | (val & 0xF);
  57:mayo_gf16.h   **** }
  58:mayo_gf16.h   **** 
  59:mayo_gf16.h   **** /* arr[idx] ^= val  (GF16 in-place add) */
  60:mayo_gf16.h   **** static inline void nibble_add(uint8_t *arr, int idx, uint8_t val)
  61:mayo_gf16.h   **** {
  62:mayo_gf16.h   ****     if (idx & 1)
  63:mayo_gf16.h   ****         arr[idx >> 1] ^= (val & 0xF) << 4;
  64:mayo_gf16.h   ****     else
  65:mayo_gf16.h   ****         arr[idx >> 1] ^= (val & 0xF);
  66:mayo_gf16.h   **** }
