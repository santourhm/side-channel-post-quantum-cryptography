  35:simpleserial-base.c **** 
  36:simpleserial-base.c **** uint8_t cmd_sign(uint8_t *msg, uint8_t len)
  37:simpleserial-base.c **** {
  38:simpleserial-base.c ****     if (!esk_loaded) {
  39:simpleserial-base.c ****         /* No key yet — echo the message back as a no-op */
  40:simpleserial-base.c ****         simpleserial_put('r', len, msg);
  41:simpleserial-base.c ****         return 0x01;
  42:simpleserial-base.c ****     }
  43:simpleserial-base.c **** 
  44:simpleserial-base.c ****     trigger_high();
  45:simpleserial-base.c ****     int ret = mayo_sign(msg, len, sig_buf);
  46:simpleserial-base.c ****     trigger_low();
  47:simpleserial-base.c **** 
  48:simpleserial-base.c ****     if (ret == 0) {
  49:simpleserial-base.c ****         simpleserial_put('r', MAYO_SIG_B, sig_buf);
  50:simpleserial-base.c ****     } else {
  51:simpleserial-base.c ****         /* Sign failed (extremely unlikely with these parameters) */
  52:simpleserial-base.c ****         simpleserial_put('e', 1, (uint8_t *)"\xFF");
  53:simpleserial-base.c ****     }
  54:simpleserial-base.c ****     return 0x00;
  55:simpleserial-base.c **** }
