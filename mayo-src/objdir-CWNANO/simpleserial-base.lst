   8:simpleserial-base.c **** /*
   9:simpleserial-base.c ****  * SimpleSerial command map:
  10:simpleserial-base.c ****  *
  11:simpleserial-base.c ****  *   'k'  16 bytes  seedsk  → expand secret key into g_mayo_esk (no trigger)
  12:simpleserial-base.c ****  *   'p'  16 bytes  message → trigger_high, mayo_sign(), trigger_low, send sig
  13:simpleserial-base.c ****  *   'x'   0 bytes          → soft reset (zero ESK)
  14:simpleserial-base.c ****  *
  15:simpleserial-base.c ****  * Signature response ('r'): MAYO_SIG_B = 66 bytes.
  16:simpleserial-base.c ****  *
  17:simpleserial-base.c ****  * For power / EM capture in ChipWhisperer:
  18:simpleserial-base.c ****  *   - trigger rises at the start of mayo_sign() (after hashing the message)
  19:simpleserial-base.c ****  *   - trigger falls when the signing loop exits
  20:simpleserial-base.c ****  *   The entire quadratic-form + linear-solve core is inside the trigger window.
  21:simpleserial-base.c ****  */
  22:simpleserial-base.c **** 
  23:simpleserial-base.c **** static uint8_t sig_buf[MAYO_SIG_B];
  24:simpleserial-base.c **** static uint8_t esk_loaded = 0;
